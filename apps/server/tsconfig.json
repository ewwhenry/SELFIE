{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2023",
    "esModuleInterop": true,
    "lib": ["esnext"],
    "types": ["node"],
    "typeRoots": ["node_modules/@types", "src/types"],

    "noImplicitAny": false,

    "noUnusedLocals": true,

    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src", "src/types"]
}
